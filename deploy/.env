# Scaffold Deployment Configuration

# ===== Service Ports =====
FRONTEND_PORT=80
BACKEND_PORT=9090

# ===== Server Configuration =====
HOST=0.0.0.0
PORT=9090
CACHE_DIR=./cache
DEBUG=false

# ===== Security Configuration =====
ACCESS_KEY=your-secret-access-key-here

# ===== Database Configuration =====
DB_ENABLE=true
DB_DRIVER=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=/app/data/scaffold.db

# ===== Redis Configuration =====
REDIS_ENABLE=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== Logging Configuration =====
LOG_LEVEL=info
LOG_FILENAME=
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=3
LOG_MAX_AGE=7
LOG_COMPRESS=true

# ===== Application Settings =====
TZ=Asia/Shanghai

# ===== Docker Build Settings =====
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1